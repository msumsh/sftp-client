#!/usr/bin/expect -f

set timeout 15

spawn java -jar ../sftp-client/target/sftp-client-1.0.jar

expect "Select an action"

send "20\r"

expect "Please enter the valid number. Attempts left: 2"

send "abc\r"

expect "Please enter the valid number. Attempts left: 1"

send -- "-1\r"

expect "Invalid action. Termination"

puts "PASSED"

expect eof